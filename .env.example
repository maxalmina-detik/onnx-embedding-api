# ============================================================
# Model + backend config — mirrors the HuggingFaceEmbedding(...) call
# ============================================================

MODEL_NAME=onnx-community/embeddinggemma-300m-ONNX
EMBED_BATCH_SIZE=8
MAX_LENGTH=512

# "cpu" for Railway (no GPU support there today). Set to "cuda" only if you
# deploy this elsewhere on a GPU-enabled host.
DEVICE=cpu

ONNX_FILE_NAME=model_quantized.onnx
ONNX_SUBFOLDER=onnx
# CPUExecutionProvider on Railway; CUDAExecutionProvider if DEVICE=cuda on a
# GPU host (and you've swapped onnxruntime -> onnxruntime-gpu in requirements.txt)
ONNX_PROVIDER=CPUExecutionProvider

# Caps ONNX Runtime's thread pools -- kept low by default to favor a small
# memory footprint over max throughput on small Railway instances.
ORT_INTRA_OP_THREADS=1
ORT_INTER_OP_THREADS=1

# query_instruction from your original snippet
QUERY_INSTRUCTION=task: search result | query:

# Optional: a separate instruction prefix applied when embedding documents
# (leave unset to use the model's default behavior)
# TEXT_INSTRUCTION=title: none | text:

# Optional: point the Hugging Face cache at a mounted Railway volume so the
# model isn't re-downloaded on every deploy/restart (see README "Persisting
# the model across deploys").
HF_HOME=/model/hf-cache

# Railway sets PORT automatically in production; only needed for local runs
PORT=8000
