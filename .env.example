# Which backend to use: "endpoint" (call out to HF) or "onnx" (run locally).
EMBEDDINGS_BACKEND=endpoint

# ============================================================
# backend=endpoint
# ============================================================

# Required: your Hugging Face access token
# https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option A (recommended for production): point at a dedicated HF Inference
# Endpoint you created at https://ui.endpoints.huggingface.co/
# Leave HF_MODEL_ID unset/ignored when this is set.
HF_EMBEDDINGS_ENDPOINT_URL=https://xxxxxxxxxxxxxxxx.us-east-1.aws.endpoints.huggingface.cloud

# Option B (prototyping only): omit HF_EMBEDDINGS_ENDPOINT_URL above and
# instead just set a model id to call the public HF Inference API.
# BAAI/bge-m3 is a solid multilingual choice (covers Indonesian).
HF_MODEL_ID=BAAI/bge-m3

# ============================================================
# backend=onnx  (only read when EMBEDDINGS_BACKEND=onnx)
# ============================================================

# HF model id (or local path) to load.
ONNX_MODEL_ID=BAAI/bge-m3

# true  = convert a normal HF checkpoint to ONNX on first load (slower cold
#         start, works with any HF model, no prior ONNX export needed)
# false = ONNX_MODEL_ID already ships ONNX weights (fast cold start), e.g.
#         onnx-community/embeddinggemma-300m-ONNX
ONNX_EXPORT=false

# Specific .onnx file to load, e.g. "model_quantized.onnx"
# ONNX_FILE_NAME=

# "cpu" (default) or "cuda" — maps to an ONNX Runtime execution provider.
# Set ONNX_PROVIDER instead for full control (e.g. TensorrtExecutionProvider).
ONNX_DEVICE=cpu
# ONNX_PROVIDER=CUDAExecutionProvider

ONNX_MAX_SEQ_LENGTH=512
ONNX_NORMALIZE=true
ONNX_BATCH_SIZE=32

# Asymmetric-retrieval instruction prefixes (leave blank for symmetric models)
# ONNX_QUERY_INSTRUCTION=
# ONNX_TEXT_INSTRUCTION=

# --- Example: EmbeddingGemma on GPU, matching a LlamaIndex config of:
#   HuggingFaceEmbedding(model_name="onnx-community/embeddinggemma-300m-ONNX",
#     device="cuda", backend="onnx", embed_batch_size=8,
#     model_kwargs={"file_name": "model_quantized.onnx", "provider": "CUDAExecutionProvider"},
#     query_instruction="task: search result | query: ")
# ONNX_MODEL_ID=onnx-community/embeddinggemma-300m-ONNX
# ONNX_EXPORT=false
# ONNX_FILE_NAME=model_quantized.onnx
# ONNX_DEVICE=cuda
# ONNX_PROVIDER=CUDAExecutionProvider
# ONNX_BATCH_SIZE=8
# ONNX_QUERY_INSTRUCTION=task: search result | query:

# Railway sets PORT automatically in production; only needed for local runs
PORT=8000
